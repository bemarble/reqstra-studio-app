{
  "name": "reqstra-studio",
  "version": "1.0.0",
  "description": "Mac desktop API client for HTTP / gRPC / GraphQL",
  "main": "./out/main/index.js",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "build:mac:x64": "npm run build && electron-builder --mac --x64",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "vitest"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.7.15",
    "@monaco-editor/react": "^4.7.0",
    "graphql": "^16.14.0",
    "graphql-request": "^7.4.0",
    "grpc-js-reflection-client": "^1.4.0",
    "path-browserify": "^1.0.1",
    "yaml": "^2.9.0",
    "zustand": "^5.0.13"
  },
  "build": {
    "appId": "com.reqstra.studio",
    "productName": "Reqstra Studio",
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "Reqstra Studio"
    },
    "files": [
      "out/**/*"
    ],
    "directories": {
      "buildResources": "build"
    }
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.18.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
